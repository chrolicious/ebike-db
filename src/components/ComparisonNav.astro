---
export interface Props {
  sections: Array<{ id: string; label: string }>;
}

const { sections } = Astro.props;
---

<nav id="comparison-nav" class="sticky top-0 z-40 bg-white border-b border-gray-200 shadow-sm">
  <div class="max-w-5xl mx-auto px-4">
    <div class="flex gap-1 overflow-x-auto py-2 scrollbar-none" id="comparison-nav-pills">
      {sections.map((section) => (
        <a
          href={`#${section.id}`}
          data-nav-id={section.id}
          class="comparison-nav-pill shrink-0 px-4 py-1.5 rounded-full text-sm font-medium transition-colors whitespace-nowrap text-gray-600 hover:bg-blue-50 hover:text-blue-700"
        >
          {section.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<style>
  .scrollbar-none {
    scrollbar-width: none;
  }
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
</style>

<script is:inline>
(function () {
  const pills = document.querySelectorAll('.comparison-nav-pill');
  const nav = document.getElementById('comparison-nav');

  function setActive(id) {
    pills.forEach((pill) => {
      const isActive = pill.getAttribute('data-nav-id') === id;
      if (isActive) {
        pill.classList.add('bg-blue-600', 'text-white');
        pill.classList.remove('text-gray-600', 'hover:bg-blue-50', 'hover:text-blue-700');
        // Scroll pill into view within the nav
        pill.scrollIntoView({ inline: 'nearest', block: 'nearest' });
      } else {
        pill.classList.remove('bg-blue-600', 'text-white');
        pill.classList.add('text-gray-600', 'hover:bg-blue-50', 'hover:text-blue-700');
      }
    });
  }

  // Offset for sticky header + nav
  const offset = (nav ? nav.offsetHeight : 60) + 64 + 8;

  const sectionIds = Array.from(pills).map((p) => p.getAttribute('data-nav-id'));

  const observers = [];

  sectionIds.forEach((id) => {
    const el = document.getElementById(id);
    if (!el) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            setActive(id);
          }
        });
      },
      {
        rootMargin: `-${offset}px 0px -60% 0px`,
        threshold: 0,
      }
    );
    observer.observe(el);
    observers.push(observer);
  });

  // Smooth scroll with offset compensation on pill click
  pills.forEach((pill) => {
    pill.addEventListener('click', function (e) {
      e.preventDefault();
      const id = pill.getAttribute('data-nav-id');
      const target = document.getElementById(id);
      if (!target) return;
      const top = target.getBoundingClientRect().top + window.scrollY - offset;
      window.scrollTo({ top, behavior: 'smooth' });
    });
  });
})();
</script>
