---
export interface Props {
  label: string;
  valueA: number;
  valueB: number;
  unitA?: string;
  unitB?: string;
  higherIsBetter?: boolean;
}

const { label, valueA, valueB, unitA, unitB, higherIsBetter = true } = Astro.props;

const max = Math.max(valueA, valueB);
const pctA = max > 0 ? Math.round((valueA / max) * 100) : 0;
const pctB = max > 0 ? Math.round((valueB / max) * 100) : 0;

// Determine winner: if higherIsBetter, higher value wins; otherwise lower value wins
const aWins = higherIsBetter ? valueA >= valueB : valueA <= valueB;
const bWins = higherIsBetter ? valueB >= valueA : valueB <= valueA;
const tied = valueA === valueB;

const colorA = !tied && aWins ? 'bg-blue-500' : 'bg-gray-300';
const colorB = !tied && bWins ? 'bg-blue-500' : 'bg-gray-300';

const displayA = unitA ?? String(valueA);
const displayB = unitB ?? String(valueB);
---

<div class="mb-5">
  <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">{label}</p>

  <!-- Model A bar -->
  <div class="flex items-center gap-3 mb-2">
    <span class="text-xs text-gray-500 w-4 shrink-0">A</span>
    <div class="flex-1 bg-gray-100 rounded-full h-3 overflow-hidden">
      <div
        class={`h-3 rounded-full transition-all ${colorA}`}
        style={`width: ${pctA}%`}
      ></div>
    </div>
    <span class={`text-sm font-semibold w-20 text-right shrink-0 ${!tied && aWins ? 'text-blue-600' : 'text-gray-500'}`}>
      {displayA}
    </span>
  </div>

  <!-- Model B bar -->
  <div class="flex items-center gap-3">
    <span class="text-xs text-gray-500 w-4 shrink-0">B</span>
    <div class="flex-1 bg-gray-100 rounded-full h-3 overflow-hidden">
      <div
        class={`h-3 rounded-full transition-all ${colorB}`}
        style={`width: ${pctB}%`}
      ></div>
    </div>
    <span class={`text-sm font-semibold w-20 text-right shrink-0 ${!tied && bWins ? 'text-blue-600' : 'text-gray-500'}`}>
      {displayB}
    </span>
  </div>
</div>
