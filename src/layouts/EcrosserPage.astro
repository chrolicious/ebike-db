---
import Layout from './Layout.astro';
import type { ECrosser } from '../data/ecrossers';
import affiliateLinksData from '../data/affiliate_links.json';

export interface Props {
	ecrosser: ECrosser;
}

const { ecrosser } = Astro.props;

const urlToSlug: Record<string, string> = {};
for (const [slug, url] of Object.entries(affiliateLinksData)) {
	urlToSlug[url] = slug;
}
function outHref(url: string): string {
	const slug = urlToSlug[url];
	return slug ? `/out/${slug}` : url;
}
const pageTitle = `${ecrosser.brand} ${ecrosser.name} - Specificaties, Prijs & Wetgeving Nederland`;
const pageDescription = `Complete gids voor de ${ecrosser.brand} ${ecrosser.name}: ${ecrosser.priceRange}, ${ecrosser.range} bereik, Nederlandse wetgeving, verzekering en waar te koop.`;

// Comparison pairs — used to generate sidebar "Vergelijk met" links
const COMPARISON_PAIRS = [
	{ a: 'surron-light-bee-x',    nameA: 'Sur-Ron Light Bee X',    b: 'talaria-sting-mx5-pro',  nameB: 'Talaria Sting MX5 Pro' },
	{ a: 'surron-light-bee-x',    nameA: 'Sur-Ron Light Bee X',    b: 'segway-dirt-ebike-x260', nameB: 'Segway X260' },
	{ a: 'talaria-sting-mx5-pro', nameA: 'Talaria Sting MX5 Pro', b: 'segway-dirt-ebike-x260', nameB: 'Segway X260' },
	{ a: 'surron-light-bee-x',    nameA: 'Sur-Ron Light Bee X',    b: 'onyx-rcr',              nameB: 'Onyx RCR' },
	{ a: 'ktm-freeride-e-xc',     nameA: 'KTM Freeride E-XC',      b: 'zero-fx',               nameB: 'Zero FX' },
	{ a: 'cake-kalk-or',          nameA: 'CAKE Kalk OR',           b: 'surron-light-bee-x',    nameB: 'Sur-Ron Light Bee X' },
	{ a: 'super73-s2',            nameA: 'Super73 S2',             b: 'himiway-cobra',         nameB: 'Himiway Cobra' },
	{ a: 'talaria-sting-mx5-pro', nameA: 'Talaria Sting MX5 Pro', b: 'onyx-rcr',              nameB: 'Onyx RCR' },
];
const comparisonLinks = COMPARISON_PAIRS
	.filter(p => p.a === ecrosser.id || p.b === ecrosser.id)
	.map(p => ({
		opponentName: p.a === ecrosser.id ? p.nameB : p.nameA,
		slug: `${p.a}-vs-${p.b}`,
	}));

// Nederland page lookup (ecrosser ID → slug)
const NEDERLAND_PAGES: Record<string, string> = {
	'surron-light-bee-x':       'surron-light-bee-x-nederland',
	'talaria-sting-mx5-pro':    'talaria-sting-nederland',
	'segway-dirt-ebike-x260':   'segway-dirt-ebike-x260-nederland',
	'super73-s2':               'super73-s2-nederland',
	'ktm-freeride-e-xc':        'ktm-freeride-e-xc-nederland',
	'zero-fx':                  'zero-fx-nederland',
	'onyx-rcr':                 'onyx-rcr-nederland',
	'cake-kalk-or':             'cake-kalk-or-nederland',
	'ubco-2x2-work-bike':       'ubco-2x2-nederland',
	'himiway-cobra':            'himiway-cobra-nederland',
	'rad-power-radrunner-2':    'rad-power-radrunner-2-nederland',
	'eskimo-fat-26':            'eskimo-fat-26-nederland',
	'surron-storm-bee':         'surron-storm-bee-nederland',
};
const nederlandSlug = NEDERLAND_PAGES[ecrosser.id] ?? null;

// Category color mapping
const catColor = ecrosser.category === 'pedelec'
	? { border: 'border-green-500', badge: 'bg-green-100 text-green-800', label: 'Geen rijbewijs' }
	: ecrosser.category === 'L3e'
	? { border: 'border-red-500', badge: 'bg-red-100 text-red-800', label: 'A/A2 rijbewijs' }
	: { border: 'border-orange-400', badge: 'bg-orange-100 text-orange-800', label: 'AM rijbewijs' };
---

<Layout title={pageTitle} description={pageDescription}>
	<!-- Hero Section -->
	<section class="bg-gradient-to-br from-gray-900 via-blue-950 to-blue-900 text-white py-14">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			{ecrosser.imageUrl ? (
				<div class="grid md:grid-cols-2 gap-10 items-center">
					<div>
						<span class={`inline-block text-xs font-semibold px-2.5 py-1 rounded-full mb-4 ${catColor.badge}`}>
							{catColor.label} &mdash; {ecrosser.category}
						</span>
						<h1 class="text-4xl md:text-5xl font-extrabold mb-3 leading-tight">
							{ecrosser.brand} {ecrosser.name}
						</h1>
						<p class="text-blue-200 mb-6 text-sm">{ecrosser.legalStatus.rijbewijs}</p>
						<div class="flex flex-wrap gap-3 mb-8">
							<div class="bg-white/10 border border-white/15 px-5 py-2.5 rounded-lg">
								<span class="text-2xl font-bold">{ecrosser.priceRange}</span>
							</div>
							<div class="bg-white/10 border border-white/15 px-5 py-2.5 rounded-lg">
								<span class="text-base">Max {ecrosser.maxSpeed} km/h</span>
							</div>
							<div class="bg-white/10 border border-white/15 px-5 py-2.5 rounded-lg">
								<span class="text-base">{ecrosser.range}</span>
							</div>
						</div>
						{ecrosser.officialUrl && (
							<a href={outHref(ecrosser.officialUrl)} target="_blank" rel="noopener nofollow"
							   class="inline-flex items-center gap-2 bg-blue-500 hover:bg-blue-400 text-white px-6 py-3 rounded-lg font-semibold transition-colors text-sm">
								Officiële website
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
							</a>
						)}
					</div>
					<div class="flex justify-center">
						<button onclick="document.getElementById('img-lightbox').showModal()" class="cursor-zoom-in group relative">
							<img
								src={ecrosser.imageUrl}
								alt={`${ecrosser.brand} ${ecrosser.name}`}
								class="max-h-72 w-auto object-contain drop-shadow-2xl rounded-xl bg-white/5 p-4 group-hover:opacity-90 transition-opacity"
								loading="eager"
							/>
							<span class="absolute bottom-3 right-3 bg-black/50 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity">&#x26F6; Vergroten</span>
						</button>
					</div>

					<!-- Lightbox -->
					<dialog id="img-lightbox" class="p-2 max-w-4xl w-full bg-gray-900 rounded-xl shadow-2xl backdrop:bg-black/80" onclick="this.close()">
						<img
							src={ecrosser.imageUrl}
							alt={`${ecrosser.brand} ${ecrosser.name}`}
							class="w-full h-auto max-h-[85vh] object-contain"
						/>
						<p class="text-center text-gray-400 text-xs mt-2">Klik ergens om te sluiten</p>
					</dialog>
				</div>
			) : (
				<div class="text-center max-w-2xl mx-auto">
					<span class={`inline-block text-xs font-semibold px-2.5 py-1 rounded-full mb-4 ${catColor.badge}`}>
						{catColor.label} &mdash; {ecrosser.category}
					</span>
					<h1 class="text-4xl md:text-5xl font-extrabold mb-3">
						{ecrosser.brand} {ecrosser.name}
					</h1>
					<p class="text-blue-200 mb-6 text-sm">{ecrosser.legalStatus.rijbewijs}</p>
					<div class="flex flex-wrap justify-center gap-3">
						<div class="bg-white/10 border border-white/15 px-5 py-2.5 rounded-lg">
							<span class="text-2xl font-bold">{ecrosser.priceRange}</span>
						</div>
						<div class="bg-white/10 border border-white/15 px-5 py-2.5 rounded-lg">
							<span class="text-base">Max {ecrosser.maxSpeed} km/h</span>
						</div>
						<div class="bg-white/10 border border-white/15 px-5 py-2.5 rounded-lg">
							<span class="text-base">{ecrosser.range}</span>
						</div>
					</div>
				</div>
			)}
		</div>
	</section>

	{ecrosser.videoId && (
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10">
			<section class="bg-white rounded-xl border border-gray-200 p-6 mb-0">
				<h2 class="text-xl font-bold mb-4">Video Review</h2>
				<div class="relative w-full" style="padding-bottom: 56.25%;">
					<iframe
						src={`https://www.youtube-nocookie.com/embed/${ecrosser.videoId}?rel=0&modestbranding=1`}
						title={`${ecrosser.brand} ${ecrosser.name} video review`}
						class="absolute inset-0 w-full h-full rounded-lg"
						allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
						allowfullscreen
						loading="lazy"
					></iframe>
				</div>
				<p class="text-xs text-gray-400 mt-2">Video via YouTube. Credits aan de originele maker.</p>
			</section>
		</div>
	)}

	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
		<div class="grid lg:grid-cols-3 gap-8">
			<!-- Main content -->
			<div class="lg:col-span-2 space-y-8">

				<!-- Dutch Legal Requirements -->
				<section class="bg-white rounded-xl border border-gray-200 p-6">
					<h2 class="text-xl font-bold text-gray-900 mb-5">Nederlandse wetgeving &mdash; {ecrosser.category}</h2>
					<div class="grid md:grid-cols-2 gap-6">
						<div>
							<h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-3">Verplicht voor weggebruik</h3>
							<ul class="space-y-2.5">
								<li class="flex items-start gap-2.5">
									<span class={`mt-0.5 w-4 h-4 rounded-full flex-shrink-0 ${ecrosser.legalStatus.rijbewijs !== 'Geen rijbewijs vereist' ? 'bg-red-100 border-2 border-red-400' : 'bg-green-100 border-2 border-green-500'}`}></span>
									<span class="text-sm"><strong>Rijbewijs:</strong> {ecrosser.legalStatus.rijbewijs}</span>
								</li>
								<li class="flex items-start gap-2.5">
									<span class={`mt-0.5 w-4 h-4 rounded-full flex-shrink-0 ${ecrosser.legalStatus.verzekering ? 'bg-red-100 border-2 border-red-400' : 'bg-green-100 border-2 border-green-500'}`}></span>
									<span class="text-sm"><strong>Verzekering:</strong> {ecrosser.legalStatus.verzekering ? 'Verplicht WA-verzekering' : 'Niet verplicht'}</span>
								</li>
								<li class="flex items-start gap-2.5">
									<span class={`mt-0.5 w-4 h-4 rounded-full flex-shrink-0 ${ecrosser.legalStatus.kenteken ? 'bg-red-100 border-2 border-red-400' : 'bg-green-100 border-2 border-green-500'}`}></span>
									<span class="text-sm"><strong>Kenteken:</strong> {ecrosser.legalStatus.kenteken ? 'Verplicht bij RDW (&euro;21,50)' : 'Niet verplicht'}</span>
								</li>
								<li class="flex items-start gap-2.5">
									<span class={`mt-0.5 w-4 h-4 rounded-full flex-shrink-0 ${ecrosser.legalStatus.helm ? 'bg-red-100 border-2 border-red-400' : 'bg-green-100 border-2 border-green-500'}`}></span>
									<span class="text-sm"><strong>Helm:</strong> {ecrosser.legalStatus.helm ? 'Verplicht' : 'Niet verplicht'}</span>
								</li>
							</ul>
						</div>
						<div>
							<h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-3">Waar mag je rijden</h3>
							<ul class="space-y-2.5">
								<li class="flex items-start gap-2.5">
									<span class={`mt-0.5 w-4 h-4 rounded-full flex-shrink-0 ${ecrosser.legalStatus.fietspad ? 'bg-green-100 border-2 border-green-500' : 'bg-red-100 border-2 border-red-400'}`}></span>
									<span class="text-sm"><strong>Fietspad:</strong> {ecrosser.legalStatus.fietspad ? 'Toegestaan' : 'Niet toegestaan'}</span>
								</li>
								<li class="flex items-start gap-2.5">
									<span class={`mt-0.5 w-4 h-4 rounded-full flex-shrink-0 ${ecrosser.legalStatus.weg ? 'bg-green-100 border-2 border-green-500' : 'bg-red-100 border-2 border-red-400'}`}></span>
									<span class="text-sm"><strong>Openbare weg:</strong> {ecrosser.legalStatus.weg ? 'Toegestaan' : 'Niet toegestaan'}</span>
								</li>
							</ul>
							{ecrosser.homologation ? (
								<div class="mt-4 p-3 bg-green-50 border border-green-200 rounded-lg">
									<p class="text-xs text-green-800"><strong>Gehomologeerd</strong> voor Nederlands weggebruik.</p>
								</div>
							) : (
								<div class="mt-4 p-3 bg-amber-50 border border-amber-200 rounded-lg">
									<p class="text-xs text-amber-800"><strong>Homologatie:</strong> Controleer voor aankoop of dit model toegelaten is op NL wegen.</p>
								</div>
							)}
						</div>
					</div>
				</section>

				<!-- Specifications -->
				<section class="bg-white rounded-xl border border-gray-200 p-6">
					<h2 class="text-xl font-bold text-gray-900 mb-5">Technische specificaties</h2>
					<div class="grid md:grid-cols-2 gap-6">
						<div>
							<h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-3">Motor &amp; prestaties</h3>
							<ul class="space-y-2.5 text-sm">
								<li class="flex justify-between py-1 border-b border-gray-50"><span class="text-gray-500">Motor</span><span class="font-medium text-right ml-4">{ecrosser.motor}</span></li>
								<li class="flex justify-between py-1 border-b border-gray-50"><span class="text-gray-500">Max snelheid</span><span class="font-medium">{ecrosser.maxSpeed} km/h</span></li>
								<li class="flex justify-between py-1 border-b border-gray-50"><span class="text-gray-500">Bereik</span><span class="font-medium">{ecrosser.range}</span></li>
								<li class="flex justify-between py-1"><span class="text-gray-500">Batterij</span><span class="font-medium text-right ml-4">{ecrosser.battery}</span></li>
							</ul>
						</div>
						<div>
							<h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-3">Fysiek</h3>
							<ul class="space-y-2.5 text-sm">
								<li class="flex justify-between py-1 border-b border-gray-50"><span class="text-gray-500">Gewicht</span><span class="font-medium">{ecrosser.weight}</span></li>
								<li class="flex justify-between py-1 border-b border-gray-50"><span class="text-gray-500">Categorie</span><span class="font-medium">{ecrosser.category}</span></li>
								<li class="flex justify-between py-1 border-b border-gray-50"><span class="text-gray-500">Beschikbaarheid</span><span class="font-medium">{ecrosser.availability}</span></li>
								<li class="flex justify-between py-1"><span class="text-gray-500">Garantie</span><span class="font-medium">{ecrosser.warranty}</span></li>
							</ul>
						</div>
					</div>
				</section>

				<!-- Features -->
				<section class="bg-white rounded-xl border border-gray-200 p-6">
					<h2 class="text-xl font-bold text-gray-900 mb-4">Kenmerken</h2>
					<div class="flex flex-wrap gap-2">
						{ecrosser.features.map((feature) => (
							<span class="bg-blue-50 text-blue-800 px-3 py-1.5 rounded-lg text-sm font-medium">{feature}</span>
						))}
					</div>
				</section>

				<!-- Pros and Cons -->
				<section class="bg-white rounded-xl border border-gray-200 p-6">
					<h2 class="text-xl font-bold text-gray-900 mb-5">Voor- en nadelen</h2>
					<div class="grid md:grid-cols-2 gap-6">
						<div>
							<h3 class="text-sm font-semibold text-green-700 mb-3">Voordelen</h3>
							<ul class="space-y-2">
								{ecrosser.pros.map((pro) => (
									<li class="flex items-start gap-2 text-sm">
										<span class="text-green-500 font-bold mt-0.5 flex-shrink-0">+</span>
										<span>{pro}</span>
									</li>
								))}
							</ul>
						</div>
						<div>
							<h3 class="text-sm font-semibold text-red-600 mb-3">Nadelen</h3>
							<ul class="space-y-2">
								{ecrosser.cons.map((con) => (
									<li class="flex items-start gap-2 text-sm">
										<span class="text-red-400 font-bold mt-0.5 flex-shrink-0">&minus;</span>
										<span>{con}</span>
									</li>
								))}
							</ul>
						</div>
					</div>
				</section>

			</div>

			<!-- Sidebar -->
			<div class="space-y-5">
				<!-- Purchase Card -->
				<div class={`bg-white rounded-xl border-2 ${catColor.border} p-5 sticky top-4`}>
					<div class="flex items-center justify-between mb-1">
						<span class="text-xs text-gray-500 font-medium uppercase tracking-wide">Adviesprijs</span>
						<span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${catColor.badge}`}>{catColor.label}</span>
					</div>
					<div class="text-3xl font-extrabold text-gray-900 mb-4">{ecrosser.priceRange}</div>
					<div class="space-y-2 mb-4">
						{ecrosser.mediamarktUrl && (
							<a href={outHref(ecrosser.mediamarktUrl)} target="_blank" rel="noopener nofollow"
							   class="flex items-center justify-between w-full bg-red-600 hover:bg-red-700 text-white py-3 px-4 rounded-lg font-semibold text-sm transition-colors">
								<span>MediaMarkt NL</span>
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
							</a>
						)}
						{ecrosser.amazonUrl && (
							<a href={outHref(ecrosser.amazonUrl)} target="_blank" rel="noopener nofollow"
							   class="flex items-center justify-between w-full bg-orange-500 hover:bg-orange-600 text-white py-3 px-4 rounded-lg font-semibold text-sm transition-colors">
								<span>Amazon NL</span>
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
							</a>
						)}
						{ecrosser.officialUrl && (
							<a href={outHref(ecrosser.officialUrl)} target="_blank" rel="noopener nofollow"
							   class="flex items-center justify-between w-full bg-gray-800 hover:bg-gray-900 text-white py-3 px-4 rounded-lg font-semibold text-sm transition-colors">
								<span>Officiële website</span>
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
							</a>
						)}
						{ecrosser.specialistDealers && ecrosser.specialistDealers.length > 0 && ecrosser.specialistDealers.slice(0, 3).map((dealer) => (
							<a href={outHref(dealer.url)} target="_blank" rel="noopener nofollow"
							   class="flex items-center justify-between w-full bg-blue-600 hover:bg-blue-700 text-white py-2.5 px-4 rounded-lg text-sm font-medium transition-colors">
								<span>{dealer.name}</span>
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
							</a>
						))}
					</div>
					<p class="text-xs text-gray-400">Prijzen en beschikbaarheid kunnen afwijken. Controleer bij de dealer.</p>
				</div>

				<!-- Service & Support -->
				<div class="bg-white rounded-xl border border-gray-200 p-5">
					<h3 class="text-sm font-bold text-gray-900 mb-3">Service &amp; support</h3>
					<ul class="space-y-2 text-sm text-gray-600">
						<li><span class="text-gray-400 text-xs">Garantie</span><br/><strong>{ecrosser.warranty}</strong></li>
						<li><span class="text-gray-400 text-xs">Service netwerk</span><br/><strong>{ecrosser.serviceNetwork}</strong></li>
						{ecrosser.dealerNetwork.length > 0 && (
							<li>
								<span class="text-gray-400 text-xs">Dealers NL</span>
								<ul class="mt-1 space-y-0.5">
									{ecrosser.dealerNetwork.map((dealer) => (
										<li class="text-xs text-gray-500">&#x2022; {dealer}</li>
									))}
								</ul>
							</li>
						)}
					</ul>
				</div>

				{nederlandSlug && (
					<a href={`/${nederlandSlug}/`}
					   class="block bg-blue-50 border border-blue-200 rounded-xl p-5 hover:bg-blue-100 transition-colors group">
						<p class="text-xs font-semibold uppercase tracking-wide text-blue-500 mb-1">Meer informatie</p>
						<h3 class="text-sm font-bold text-gray-900 group-hover:text-blue-700">
							{ecrosser.brand} {ecrosser.name} in Nederland &rarr;
						</h3>
						<p class="text-xs text-gray-500 mt-1">Rijbewijs, kenteken, dealers en koopgids</p>
					</a>
				)}

				{ecrosser.certifications.length > 0 && (
					<div class="bg-white rounded-xl border border-gray-200 p-5">
						<h3 class="text-sm font-bold text-gray-900 mb-3">Certificeringen</h3>
						<div class="flex flex-wrap gap-2">
							{ecrosser.certifications.map((cert) => (
								<span class="bg-green-50 text-green-800 border border-green-200 px-3 py-1 rounded-full text-xs font-medium">{cert}</span>
							))}
						</div>
					</div>
				)}

				{comparisonLinks.length > 0 && (
					<div class="bg-white rounded-xl border border-gray-200 p-5">
						<h3 class="text-sm font-bold text-gray-900 mb-3">Vergelijk met</h3>
						<div class="space-y-2">
							{comparisonLinks.map(({ opponentName, slug }) => (
								<a
									href={`/vergelijk/${slug}`}
									class="flex items-center justify-between p-2.5 bg-gray-50 hover:bg-blue-50 border border-gray-200 hover:border-blue-300 rounded-lg transition-colors group"
								>
									<span class="text-sm font-medium text-gray-700 group-hover:text-blue-700">{opponentName}</span>
									<span class="text-xs text-blue-500 group-hover:text-blue-700 shrink-0 ml-2">vs &rarr;</span>
								</a>
							))}
						</div>
					</div>
				)}
			</div>
		</div>
	</div>

	<!-- Mobile sticky CTA -->
	<div class="fixed bottom-0 left-0 right-0 md:hidden bg-white border-t border-gray-200 px-4 py-3 z-40 shadow-lg">
		<div class="flex items-center gap-3 max-w-lg mx-auto">
			<span class="text-lg font-extrabold text-gray-900 flex-shrink-0">{ecrosser.priceRange}</span>
			{ecrosser.officialUrl && (
				<a href={outHref(ecrosser.officialUrl)} target="_blank" rel="noopener nofollow"
				   class="flex-1 bg-blue-600 text-white text-center py-2.5 rounded-lg font-semibold text-sm hover:bg-blue-700 transition-colors">
					Bekijk bij dealer &rarr;
				</a>
			)}
		</div>
	</div>

	<!-- Structured Data -->
	<script type="application/ld+json" is:inline set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Product",
		"name": `${ecrosser.brand} ${ecrosser.name}`,
		"brand": { "@type": "Brand", "name": ecrosser.brand },
		"description": pageDescription,
		"category": ecrosser.category,
		"offers": {
			"@type": "Offer",
			"price": ecrosser.price,
			"priceCurrency": "EUR",
			"availability": ecrosser.availability === 'In voorraad'
				? "https://schema.org/InStock"
				: "https://schema.org/PreOrder"
		},
		"additionalProperty": [
			{ "@type": "PropertyValue", "name": "Max Speed", "value": `${ecrosser.maxSpeed} km/h` },
			{ "@type": "PropertyValue", "name": "Range", "value": ecrosser.range },
			{ "@type": "PropertyValue", "name": "Motor", "value": ecrosser.motor },
			{ "@type": "PropertyValue", "name": "Battery", "value": ecrosser.battery }
		]
	})} />
</Layout>
