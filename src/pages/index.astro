---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="E-Bike Database Nederland - Complete gids voor elektrische fietsen en crossers"
  description="Ontdek de beste elektrische fietsen en e-crossers voor Nederland. Vergelijk specificaties, prijzen en wetgeving voor alle merken: Surron, Talaria, RadPower, Super73 en meer."
>
  <div class="bg-blue-600 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl md:text-6xl font-bold mb-6">
          E-Bike Database Nederland
        </h1>
        <p class="text-xl md:text-2xl mb-8 text-blue-100">
          Complete gids voor elektrische fietsen en e-crossers in Nederland
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#nederlandse-crossers" class="bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors">
            Nederlandse E-Crossers
          </a>
          <a href="/vergelijk" class="border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-blue-600 transition-colors">
            Vergelijk Modellen
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      <div class="text-center">
        <div class="text-4xl font-bold text-blue-600 mb-2">25+</div>
        <div class="text-gray-600">E-bike merken</div>
      </div>
      <div class="text-center">
        <div class="text-4xl font-bold text-blue-600 mb-2">100+</div>
        <div class="text-gray-600">Modellen getest</div>
      </div>
      <div class="text-center">
        <div class="text-4xl font-bold text-blue-600 mb-2">100%</div>
        <div class="text-gray-600">Nederlandse wetgeving</div>
      </div>
    </div>

    <!-- Nederlandse E-Crossers Section -->
    <section id="nederlandse-crossers" class="mb-16">
      <h2 class="text-3xl font-bold text-center mb-8">Nederlandse E-Crossers</h2>
      <p class="text-lg text-gray-600 text-center mb-12 max-w-3xl mx-auto">
        Ontdek onze selectie van e-crossers die volledig voldoen aan de Nederlandse wetgeving. 
        Van budgetvriendelijke opties tot premium modellen - allemaal met Nederlandse dealers en support.
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Lectric XP Nederland -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
          <div class="p-6">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-xl font-semibold">Lectric XP Nederland</h3>
              <span class="text-2xl font-bold text-green-600">€999</span>
            </div>
            <p class="text-gray-600 mb-4">Budget folding e-bike onder €1000</p>
            <div class="space-y-2 text-sm text-gray-700 mb-6">
              <div>• 500W motor - Reguliere e-bike</div>
              <div>• Opvouwbaar design</div>
              <div>• Geen kenteken/rijbewijs nodig</div>
            </div>
            <a href="/lectric-xp-nederland" class="block w-full bg-blue-600 text-white text-center py-2 rounded-lg hover:bg-blue-700 transition-colors">
              Meer info →
            </a>
          </div>
        </div>

        <!-- RadRunner Plus Nederland -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
          <div class="p-6">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-xl font-semibold">RadRunner Plus Nederland</h3>
              <span class="text-2xl font-bold text-green-600">€1,699</span>
            </div>
            <p class="text-gray-600 mb-4">Familie cargo e-bike voor dagelijks transport</p>
            <div class="space-y-2 text-sm text-gray-700 mb-6">
              <div>• 750W motor - Snorfiets</div>
              <div>• Cargo capaciteit</div>
              <div>• Passagier mogelijkheid</div>
            </div>
            <a href="/radrunner-plus-nederland" class="block w-full bg-blue-600 text-white text-center py-2 rounded-lg hover:bg-blue-700 transition-colors">
              Meer info →
            </a>
          </div>
        </div>

        <!-- Super73 S2 Nederland -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
          <div class="p-6">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-xl font-semibold">Super73 S2 Nederland</h3>
              <span class="text-2xl font-bold text-green-600">€2,199</span>
            </div>
            <p class="text-gray-600 mb-4">Lifestyle e-bike met California stijl</p>
            <div class="space-y-2 text-sm text-gray-700 mb-6">
              <div>• 750W mid-drive - Snorfiets</div>
              <div>• Uniek design</div>
              <div>• Sterke community</div>
            </div>
            <a href="/super73-s2-nederland" class="block w-full bg-blue-600 text-white text-center py-2 rounded-lg hover:bg-blue-700 transition-colors">
              Meer info →
            </a>
          </div>
        </div>

        <!-- Talaria Sting Nederland -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
          <div class="p-6">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-xl font-semibold">Talaria Sting Nederland</h3>
              <span class="text-2xl font-bold text-green-600">€4,899</span>
            </div>
            <p class="text-gray-600 mb-4">Budget alternatief voor Surron Light Bee</p>
            <div class="space-y-2 text-sm text-gray-700 mb-6">
              <div>• 6000W motor - Snorfiets</div>
              <div>• 72V batterij systeem</div>
              <div>• €300 goedkoper dan Surron</div>
            </div>
            <a href="/talaria-sting-nederland" class="block w-full bg-blue-600 text-white text-center py-2 rounded-lg hover:bg-blue-700 transition-colors">
              Meer info →
            </a>
          </div>
        </div>

        <!-- Zero FX Nederland -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
          <div class="p-6">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-xl font-semibold">Zero FX Nederland</h3>
              <span class="text-2xl font-bold text-green-600">€12,995</span>
            </div>
            <p class="text-gray-600 mb-4">Premium elektrische motor voor A1 rijbewijs</p>
            <div class="space-y-2 text-sm text-gray-700 mb-6">
              <div>• 34kW motor - A1 motor</div>
              <div>• 146km bereik</div>
              <div>• Professionele motor</div>
            </div>
            <a href="/zero-fx-nederland" class="block w-full bg-blue-600 text-white text-center py-2 rounded-lg hover:bg-blue-700 transition-colors">
              Meer info →
            </a>
          </div>
        </div>

        <!-- KTM Freeride E-XC Nederland -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
          <div class="p-6">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-xl font-semibold">KTM Freeride E-XC Nederland</h3>
              <span class="text-2xl font-bold text-green-600">€11,999</span>
            </div>
            <p class="text-gray-600 mb-4">Premium off-road elektrische crosser</p>
            <div class="space-y-2 text-sm text-gray-700 mb-6">
              <div>• 18kW motor - A1 motor</div>
              <div>• WP vering</div>
              <div>• Racing erfgoed</div>
            </div>
            <a href="/ktm-freeride-e-xc-nederland" class="block w-full bg-blue-600 text-white text-center py-2 rounded-lg hover:bg-blue-700 transition-colors">
              Meer info →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold text-center mb-8">Categorieën</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center bg-white p-8 rounded-lg shadow-md">
          <div class="text-4xl mb-4">🚴‍♂️</div>
          <h3 class="text-xl font-semibold mb-4">Reguliere E-bikes</h3>
          <p class="text-gray-600 mb-4">Tot 25km/h, geen kenteken nodig</p>
          <a href="/reguliere-ebikes" class="text-blue-600 hover:underline">Bekijk modellen →</a>
        </div>
        <div class="text-center bg-white p-8 rounded-lg shadow-md">
          <div class="text-4xl mb-4">🛴</div>
          <h3 class="text-xl font-semibold mb-4">Snorfietsen</h3>
          <p class="text-gray-600 mb-4">Tot 25km/h, kenteken wel - rijbewijs niet</p>
          <a href="/snorfietsen" class="text-blue-600 hover:underline">Bekijk modellen →</a>
        </div>
        <div class="text-center bg-white p-8 rounded-lg shadow-md">
          <div class="text-4xl mb-4">🏍️</div>
          <h3 class="text-xl font-semibold mb-4">A1 Motoren</h3>
          <p class="text-gray-600 mb-4">Rijbewijs, kenteken en verzekering verplicht</p>
          <a href="/a1-motoren" class="text-blue-600 hover:underline">Bekijk modellen →</a>
        </div>
      </div>
    </section>

    <!-- Legal Info -->
    <section class="bg-orange-50 p-8 rounded-lg">
      <h2 class="text-2xl font-bold mb-4 text-orange-800">⚠️ Nederlandse Wetgeving</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-gray-700">
        <div>
          <h3 class="font-semibold mb-2">Reguliere E-bike:</h3>
          <ul class="space-y-1 text-sm">
            <li>• Maximaal 25 km/h</li>
            <li>• Maximaal 250W nominaal vermogen</li>
            <li>• Geen kenteken/rijbewijs/verzekering</li>
            <li>• Helm niet verplicht</li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold mb-2">Snorfiets:</h3>
          <ul class="space-y-1 text-sm">
            <li>• Maximaal 25 km/h</li>
            <li>• Kenteken verplicht</li>
            <li>• Geen rijbewijs nodig vanaf 16 jaar</li>
            <li>• Helm verplicht</li>
          </ul>
        </div>
      </div>
      <p class="mt-4 text-sm text-gray-600">
        <strong>Disclaimer:</strong> Controleer altijd de laatste wetgeving bij RDW. 
        Informatie geldig per april 2024.
      </p>
    </section>
  </div>
</Layout>