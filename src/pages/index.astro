---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="E-Bike Database Nederland - Complete gids voor elektrische fietsen en crossers"
  description="Ontdek de beste elektrische fietsen en e-crossers voor Nederland. Vergelijk specificaties, prijzen en wetgeving voor alle merken: Surron, Talaria, RadPower, Super73 en meer."
>
  <div class="bg-blue-600 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl md:text-6xl font-bold mb-6">
          E-Bike Database Nederland
        </h1>
        <p class="text-xl md:text-2xl mb-8 text-blue-100">
          Complete gids voor elektrische fietsen en e-crossers in Nederland
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#nederlandse-crossers" class="bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors">
            Nederlandse E-Crossers
          </a>
          <a href="/vergelijk" class="border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-blue-600 transition-colors">
            Vergelijk Modellen
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      <div class="text-center">
        <div class="text-4xl font-bold text-blue-600 mb-2">15</div>
        <div class="text-gray-600">E-bike merken</div>
      </div>
      <div class="text-center">
        <div class="text-4xl font-bold text-blue-600 mb-2">19</div>
        <div class="text-gray-600">Modellen gedocumenteerd</div>
      </div>
      <div class="text-center">
        <div class="text-4xl font-bold text-blue-600 mb-2">100%</div>
        <div class="text-gray-600">Nederlandse wetgeving</div>
      </div>
    </div>

    <!-- Nederlandse E-Crossers Section -->
    <section id="nederlandse-crossers" class="mb-16">
      <h2 class="text-3xl font-bold text-center mb-8">Nederlandse E-Crossers</h2>
      <p class="text-lg text-gray-600 text-center mb-12 max-w-3xl mx-auto">
        Onze selectie van e-crossers met informatie over Nederlandse wetgeving, dealers en prijzen.
        Van budget tot premium &mdash; inclusief rijbewijs- en kentekenvereisten per model.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Segway X260 Nederland -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
          <div class="p-6">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-xl font-semibold">Segway Dirt eBike X260</h3>
              <span class="text-2xl font-bold text-green-600">&euro;3.499</span>
            </div>
            <p class="text-gray-600 mb-4">Elektrische crosser bij MediaMarkt &amp; 57 dealers</p>
            <div class="space-y-2 text-sm text-gray-700 mb-6">
              <div>5kW motor &mdash; bromfiets (L1e-B)</div>
              <div>74V 31.2Ah (2.309Wh), GPS ingebouwd</div>
              <div>AM rijbewijs en geel kenteken vereist</div>
            </div>
            <a href="/segway-dirt-ebike-x260-nederland" class="block w-full bg-blue-600 text-white text-center py-2 rounded-lg hover:bg-blue-700 transition-colors">
              Meer info &rarr;
            </a>
          </div>
        </div>

        <!-- Super73 S2 Nederland -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
          <div class="p-6">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-xl font-semibold">Super73 S2 Nederland</h3>
              <span class="text-2xl font-bold text-green-600">&euro;3.299</span>
            </div>
            <p class="text-gray-600 mb-4">Lifestyle e-bike met retro motorfiets-looks</p>
            <div class="space-y-2 text-sm text-gray-700 mb-6">
              <div>750W mid-drive &mdash; snorfiets (L1e-B)</div>
              <div>48V 14Ah (672Wh) batterij</div>
              <div>AM rijbewijs en geel kenteken vereist</div>
            </div>
            <a href="/super73-s2-nederland" class="block w-full bg-blue-600 text-white text-center py-2 rounded-lg hover:bg-blue-700 transition-colors">
              Meer info &rarr;
            </a>
          </div>
        </div>

        <!-- Talaria Sting Nederland -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
          <div class="p-6">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-xl font-semibold">Talaria Sting Nederland</h3>
              <span class="text-2xl font-bold text-green-600">&euro;4.899</span>
            </div>
            <p class="text-gray-600 mb-4">Elektrische crosser met Samsung-batterij</p>
            <div class="space-y-2 text-sm text-gray-700 mb-6">
              <div>6.000W motor &mdash; bromfiets (L1e-B)</div>
              <div>60V 28.8Ah Samsung-cellen</div>
              <div>AM rijbewijs en geel kenteken vereist</div>
            </div>
            <a href="/talaria-sting-nederland" class="block w-full bg-blue-600 text-white text-center py-2 rounded-lg hover:bg-blue-700 transition-colors">
              Meer info &rarr;
            </a>
          </div>
        </div>

        <!-- Zero FX Nederland -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
          <div class="p-6">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-xl font-semibold">Zero FX Nederland</h3>
              <span class="text-2xl font-bold text-green-600">&euro;12.995</span>
            </div>
            <p class="text-gray-600 mb-4">Premium elektrische motor, A1-rijbewijs categorie</p>
            <div class="space-y-2 text-sm text-gray-700 mb-6">
              <div>34kW motor &mdash; motorfiets (L3e-A1)</div>
              <div>7,2 kWh batterij, tot 146 km bereik</div>
              <div>A1 rijbewijs en kenteken verplicht</div>
            </div>
            <a href="/zero-fx-nederland" class="block w-full bg-blue-600 text-white text-center py-2 rounded-lg hover:bg-blue-700 transition-colors">
              Meer info &rarr;
            </a>
          </div>
        </div>

        <!-- KTM Freeride E-XC Nederland -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
          <div class="p-6">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-xl font-semibold">KTM Freeride E-XC Nederland</h3>
              <span class="text-2xl font-bold text-green-600">&euro;11.999</span>
            </div>
            <p class="text-gray-600 mb-4">Elektrische enduro met WP-vering en 3,9 kWh batterij</p>
            <div class="space-y-2 text-sm text-gray-700 mb-6">
              <div>18kW motor &mdash; motorfiets (L3e)</div>
              <div>3x KTM PowerPack (3,9 kWh totaal)</div>
              <div>A rijbewijs en kenteken verplicht</div>
            </div>
            <a href="/ktm-freeride-e-xc-nederland" class="block w-full bg-blue-600 text-white text-center py-2 rounded-lg hover:bg-blue-700 transition-colors">
              Meer info &rarr;
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold text-center mb-8">Categorie&euml;n</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center bg-white p-8 rounded-lg shadow-md">
          <h3 class="text-xl font-semibold mb-4">Reguliere e-bikes</h3>
          <p class="text-gray-600 mb-4">Max. 250W nominaal, 25 km/h trapondersteuning. Geen kenteken of rijbewijs nodig.</p>
          <a href="/vergelijk" class="text-blue-600 hover:underline">Bekijk overzicht &rarr;</a>
        </div>
        <div class="text-center bg-white p-8 rounded-lg shadow-md">
          <h3 class="text-xl font-semibold mb-4">Bromfietsen (L1e-B)</h3>
          <p class="text-gray-600 mb-4">Max. 45 km/h, geel kenteken. AM rijbewijs verplicht vanaf 16 jaar. Helm verplicht.</p>
          <a href="/vergelijk" class="text-blue-600 hover:underline">Bekijk overzicht &rarr;</a>
        </div>
        <div class="text-center bg-white p-8 rounded-lg shadow-md">
          <h3 class="text-xl font-semibold mb-4">Motorfietsen (L3e)</h3>
          <p class="text-gray-600 mb-4">A1 of A rijbewijs verplicht. Kenteken, WA-verzekering en motorhelm verplicht.</p>
          <a href="/vergelijk" class="text-blue-600 hover:underline">Bekijk overzicht &rarr;</a>
        </div>
      </div>
    </section>

    <!-- Legal Info -->
    <section class="bg-orange-50 p-8 rounded-lg">
      <h2 class="text-2xl font-bold mb-4 text-orange-800">Nederlandse wetgeving op hoofdlijnen</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-gray-700">
        <div>
          <h3 class="font-semibold mb-2">Reguliere e-bike:</h3>
          <ul class="space-y-1 text-sm">
            <li>Maximaal 250W nominaal vermogen</li>
            <li>Trapondersteuning tot 25 km/h</li>
            <li>Geen kenteken, rijbewijs of verzekering</li>
            <li>Helm niet verplicht</li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold mb-2">Bromfiets (L1e-B):</h3>
          <ul class="space-y-1 text-sm">
            <li>Maximaal 45 km/h</li>
            <li>Geel kenteken verplicht (RDW, &euro;21,50)</li>
            <li>AM rijbewijs verplicht (vanaf 16 jaar)</li>
            <li>Goedgekeurde helm verplicht</li>
          </ul>
        </div>
      </div>
      <p class="mt-4 text-sm text-gray-600">
        Meer details: <a href="/wetgeving" class="text-blue-600 hover:underline">Wetgeving per categorie</a> &mdash; inclusief RDW-kentekenprocedure en CBR-rijbewijsinfo.
        <br>Controleer altijd de actuele informatie bij <a href="https://www.rdw.nl" class="text-blue-600 hover:underline" rel="noopener">RDW.nl</a>.
        Informatie bijgewerkt april 2026.
      </p>
    </section>
  </div>
</Layout>
