					<div class="bg-white p-6 rounded-lg shadow-md">
						<div class="flex items-center mb-4">
							<span class="font-bold text-gray-700 mr-4">[Lectric eBikes]</span>
							<div>
								<h3 class="font-bold">Lectric eBikes</h3>
								<span class="text-sm text-green-600">Officiële Website</span>
							</div>
						</div>
						<p class="text-gray-600 mb-4">Direct van de fabrikant. Nederlandse levering en 2 jaar garantie.</p>
						<div class="space-y-2 text-sm mb-4">
							<div>✅ Laagste prijs gegarandeerd</div>
							<div>✅ 2 jaar internationale garantie</div>
							<div>✅ 14 dagen retourrecht</div>
						</div>
						<a href={affiliateLinks.lectricOfficial}
						   class="block bg-purple-600 hover:bg-purple-700 text-white text-center py-3 rounded-lg font-semibold transition-colors"
						   target="_blank" rel="noopener">
							Bestellen bij Lectric
						</a>
					</div>

