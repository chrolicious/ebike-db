								<li>• 7-speed Shimano versnellingen</li>
								<li>• Mechanische schijfremmen voor/achter</li>
								<li>• 180mm rotors</li>
								<li>• Remhendels met motor cut-off</li>
							</ul>
						</div>
						<div>
							<h4 class="font-semibold mb-4">Comfort</h4>
							<ul class="space-y-2 text-sm text-gray-600">
								<li>• Verstelbaar stuur en zadel</li>
								<li>• Comfortabel ergonomisch zadel</li>
								<li>• Stevige aluminium pedalen</li>
								<li>• 20" x 3" fat tires</li>
							</ul>
						</div>
						<div>
							<h4 class="font-semibold mb-4">Accessoires</h4>
							<ul class="space-y-2 text-sm text-gray-600">
								<li>• LED voorlicht & achterlicht</li>
								<li>• LCD display met USB poort</li>
								<li>• Achterrek (25kg draagvermogen)</li>
								<li>• Spatborden voor/achter</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Where to Buy Section -->
		<section id="kopen" class="py-16">
			<div class="container mx-auto px-4">
				<h2 class="text-4xl font-bold text-center mb-12">🛒 Waar te Kopen in Nederland</h2>

				<!-- Official Dealer Network -->
