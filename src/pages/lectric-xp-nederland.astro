							<div class="flex justify-between">
								<span class="font-semibold">Wielmaat</span>
								<span>20" Fat Tires</span>
							</div>
						</div>
					</div>
				</div>

				<div class="mt-12 bg-white p-8 rounded-lg shadow-md">
					<h3 class="text-xl font-bold mb-6 text-center">🚴 Rijcomfort & Features</h3>
