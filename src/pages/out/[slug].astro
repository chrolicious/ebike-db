---
import affiliateLinks from '../../data/affiliate_links.json';

export function getStaticPaths() {
  return Object.entries(affiliateLinks).map(([slug, destination]) => ({
    params: { slug },
    props: { destination, slug },
  }));
}

const { destination, slug } = Astro.props;
---
<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <title>Doorsturen...</title>
    <meta http-equiv="refresh" content={`1; url=${destination}`} />
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <p style="font-family:sans-serif;color:#555;padding:2rem">
      Je wordt doorgestuurd naar <a href={destination}>{destination}</a>...
    </p>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-5HSQLSRJML"></script>
    <script define:vars={{ destination, slug }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-5HSQLSRJML');

      // Fire affiliate click event, then redirect
      gtag('event', 'affiliate_click', {
        event_category: 'outbound',
        event_label: slug,
        transport_type: 'beacon',
        event_callback: function() { window.location.href = destination; }
      });
      // Fallback redirect if callback doesn't fire
      setTimeout(function() { window.location.href = destination; }, 800);
    </script>
  </body>
</html>
