						<a href={affiliateLinks.bikester}
						   class="block bg-green-600 hover:bg-green-700 text-white text-center py-3 rounded-lg font-semibold transition-colors"
						   target="_blank" rel="noopener">
							Bekijk bij Bikester
						</a>
					</div>

					<div class="bg-white p-6 rounded-lg shadow-md">
						<div class="flex items-center mb-4">
							<span class="font-bold text-gray-700 mr-4">[Coolblue]</span>
							<div>
								<h3 class="font-bold">Coolblue</h3>
								<span class="text-sm text-blue-600">Nederlandse Service</span>
							</div>
						</div>
						<p class="text-gray-600 mb-4">Bekende Nederlandse webwinkel. Snelle levering en installatie service.</p>
						<div class="space-y-2 text-sm mb-4">
							<div>✅ Gratis installatie service</div>
							<div>✅ Nederlandse klantenservice</div>
							<div>✅ Voor 23:59 besteld = morgen in huis</div>
						</div>
						<a href={affiliateLinks.coolblue}
						   class="block bg-blue-600 hover:bg-blue-700 text-white text-center py-3 rounded-lg font-semibold transition-colors"
						   target="_blank" rel="noopener">
							Bekijk bij Coolblue
						</a>
					</div>
				</div>

				<!-- Price Comparison Table -->
				<div class="bg-white rounded-lg shadow-lg overflow-hidden mb-8">
					<div class="bg-gray-100 px-6 py-4 border-b">
						<h3 class="text-xl font-bold">💰 Prijsvergelijking Super73 S2 Nederland</h3>
					</div>
					<div class="overflow-x-auto">
						<table class="w-full">
							<thead class="bg-gray-50">
								<tr>
									<th class="px-6 py-3 text-left font-semibold">Dealer</th>
									<th class="px-6 py-3 text-center font-semibold">Basisprijs</th>
									<th class="px-6 py-3 text-center font-semibold">Incl. Setup</th>
									<th class="px-6 py-3 text-center font-semibold">Levertijd</th>
									<th class="px-6 py-3 text-center font-semibold">Voordelen</th>
								</tr>
							</thead>
							<tbody>
								<tr class="border-t">
									<td class="px-6 py-4 font-semibold">Super73 Europe</td>
									<td class="px-6 py-4 text-center text-green-600 font-bold">€2.199</td>
									<td class="px-6 py-4 text-center">€2.473</td>
									<td class="px-6 py-4 text-center text-green-600">1-2 weken</td>
