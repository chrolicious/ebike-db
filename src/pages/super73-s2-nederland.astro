---
// Super73 S2 - Complete Dutch Landing Page Template  
import Layout from '../layouts/Layout.astro';
import ComplianceAlert from '../components/ComplianceAlert.astro';
import TechnicalSpecs from '../components/TechnicalSpecs.astro';

// SEO & Meta Data
const title = "Super73 S2 Kopen Nederland 2026 - Complete Gids & Prijzen";
const description = "Super73 S2 volledig overzicht: Nederlandse wetgeving, verzekering, kenteken, dealers en beste prijzen. Lifestyle e-bike met unieke stijl.";
const keywords = "super73 s2 nederland, lifestyle e-bike kopen, elektrische motor nederland, super73 dealers, s2 prijs, cruiser e-bike";

// Product Data
const productData = {
	model: "S2",
	brand: "Super73", 
	basePrice: 2199,
	weight: 32,
	range: "40-65",
	topSpeed: 32,
	batteryCapacity: "48V 14.5Ah", 
	motor: "750W Mid-Drive",
	legalStatus: "Snorfiets (25km/h begrenzer vereist)",
	homologation: "L1e-B"
};

// Affiliate Links Data
const affiliateLinks = {
	super73Official: "https://eu.super73.com/products/s2?utm_source=ebikedb&utm_campaign=nl-affiliate",
	mediamarkt: "https://mediamarkt.nl/super73-s2?affiliate=ebike-db-001", 
	amazon: "https://amazon.nl/dp/B09SUP123?tag=ebikedb-21",
	coolblue: "https://coolblue.nl/super73-s2?affiliate=ebike-db-001",
	bikester: "https://bikester.nl/super73?partner=ebikedb"
};

// Legal Requirements Data
const legalRequirements = {
	license: "Snorfiets: geen rijbewijs nodig vanaf 16 jaar",
	insurance: "WA verzekering verplicht", 
	registration: "RDW kenteken vereist",
	helmet: "ECE-22.05 helm verplicht",
	modifications: "25km/h begrenzer voor openbare weg"
};
---

<Layout title={title} description={description}>
	<!-- Structured Data -->
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "Product", 
		"name": "Super73 S2",
		"brand": {
			"@type": "Brand",
			"name": "Super73"
		},
		"description": "Lifestyle elektrische fiets met unieke retro-futuristische stijl en krachtige prestaties",
		"category": "Electric Lifestyle Bike",
		"offers": {
			"@type": "Offer",
			"priceCurrency": "EUR",
			"price": "2199.00", 
			"availability": "https://schema.org/InStock",
			"seller": {
				"@type": "Organization", 
				"name": "Super73 Europe"
			}
		},
		"aggregateRating": {
			"@type": "AggregateRating",
			"ratingValue": "4.3",
			"reviewCount": "256"
		}
	}
	</script>

	<main class="super73-landing">
		<!-- Hero Section -->
		<section class="hero bg-gradient-to-r from-orange-600 to-red-600 text-white py-20">
			<div class="container mx-auto px-4">
				<div class="grid md:grid-cols-2 gap-12 items-center">
					<div>
						<h1 class="text-4xl md:text-6xl font-bold mb-6">
							Super73 S2
							<span class="block text-2xl md:text-3xl text-orange-200">
								Lifestyle Meets Performance
							</span>
						</h1>
						<p class="text-xl mb-8 leading-relaxed">
							De iconische Californiër nu in Nederland. 750W mid-drive motor,
							unieke stijl en straatlegaal te maken met begrenzer.
						</p>
						<div class="flex flex-wrap gap-4">
							<a href="#kopen" class="bg-white text-orange-600 hover:bg-gray-100 px-8 py-4 rounded-lg font-bold text-lg transition-colors">
								🛒 Direct Kopen vanaf €2.199
							</a>
							<a href="#wetgeving" class="border-2 border-white hover:bg-white hover:text-orange-600 px-8 py-4 rounded-lg font-bold text-lg transition-colors">
								📋 Nederlandse Wetgeving
							</a>
						</div>
					</div>
					<div class="relative">
						<div class="w-full h-64 bg-gray-200 rounded-lg flex items-center justify-center"><span class="text-gray-500 text-xl">Foto binnenkort beschikbaar</span></div>
						<div class="absolute top-4 right-4 bg-purple-500 text-white px-4 py-2 rounded-lg font-bold">
							🎨 Lifestyle Icon
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Compliance Alert -->
		<ComplianceAlert
			type="warning"
			message="Super73 S2 heeft 32km/h topsnelheid - 25km/h begrenzer verplicht voor openbare weg in Nederland."
			actionText="Bekijk Wetgeving" 
			actionLink="#wetgeving"
		/>

		<!-- Quick Specs Grid -->
		<section class="py-16 bg-gray-50">
			<div class="container mx-auto px-4">
				<div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
					<div class="bg-white p-6 rounded-lg shadow-md">
						<div class="text-3xl font-bold text-orange-600 mb-2">750W</div>
						<div class="text-gray-600">Mid-Drive Motor</div>
					</div>
					<div class="bg-white p-6 rounded-lg shadow-md">
						<div class="text-3xl font-bold text-red-600 mb-2">65km</div>
						<div class="text-gray-600">Max Bereik</div>
					</div>
					<div class="bg-white p-6 rounded-lg shadow-md">
						<div class="text-3xl font-bold text-purple-600 mb-2">32kg</div>
						<div class="text-gray-600">Gewicht</div>
					</div>
					<div class="bg-white p-6 rounded-lg shadow-md">
						<div class="text-3xl font-bold text-green-600 mb-2">€2.199</div>
						<div class="text-gray-600">Vanaf Prijs</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Why Super73 Section -->
		<section class="py-16">
			<div class="container mx-auto px-4">
				<h2 class="text-4xl font-bold text-center mb-12">Waarom Super73 S2?</h2>

				<div class="grid lg:grid-cols-3 gap-8">
					<div class="bg-orange-50 p-8 rounded-lg text-center">
						<div class="w-16 h-16 bg-orange-500 rounded-full flex items-center justify-center mx-auto mb-6">
							<span class="text-2xl">🎨</span>
						</div>
						<h3 class="text-xl font-bold mb-4">Unieke Stijl</h3>
						<p class="text-gray-600">
							Retro-futuristische design dat overal bekeken wordt. 
							Meer dan vervoer - het is een statement.
						</p>
						<ul class="mt-4 space-y-2 text-sm text-orange-700">
							<li>• Iconisch banana-zadel design</li>
							<li>• Keuze uit 5 kleuren</li>
							<li>• Instagram-waardig uiterlijk</li>
						</ul>
					</div>

					<div class="bg-red-50 p-8 rounded-lg text-center">
						<div class="w-16 h-16 bg-red-500 rounded-full flex items-center justify-center mx-auto mb-6">
							<span class="text-2xl">⚡</span>
						</div>
						<h3 class="text-xl font-bold mb-4">Krachtige Prestaties</h3>
						<p class="text-gray-600">
							750W mid-drive motor voor superieure kracht en efficiëntie. 
							Voelt aan als een lichte motorfiets.
						</p>
						<ul class="mt-4 space-y-2 text-sm text-red-700">
							<li>• 750W Bafang mid-drive motor</li>
							<li>• 80Nm koppel voor heuvels</li>
							<li>• 32 km/h topsnelheid (onbegrensd)</li>
						</ul>
					</div>

					<div class="bg-purple-50 p-8 rounded-lg text-center">
						<div class="w-16 h-16 bg-purple-500 rounded-full flex items-center justify-center mx-auto mb-6">
							<span class="text-2xl">🌎</span>
						</div>
						<h3 class="text-xl font-bold mb-4">Community & Cultuur</h3>
						<p class="text-gray-600">
							Word onderdeel van de wereldwijde Super73 community. 
							Nederlandse riders organiseren regelmatig meet-ups.
						</p>
						<ul class="mt-4 space-y-2 text-sm text-purple-700">
							<li>• Actieve Nederlandse Facebook groep</li>
							<li>• Maandelijkse group rides</li>
							<li>• Exclusive Super73 accessoires</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- Super73 vs Alternatives -->
		<section class="py-16 bg-gray-50">
			<div class="container mx-auto px-4">
				<h2 class="text-4xl font-bold text-center mb-12">Super73 S2 vs Alternatieven</h2>
				<div class="overflow-x-auto">
					<table class="w-full bg-white rounded-lg shadow-lg">
						<thead class="bg-gray-100">
							<tr>
								<th class="px-6 py-4 text-left font-bold">Model</th>
								<th class="px-6 py-4 text-center font-bold">Prijs</th>
								<th class="px-6 py-4 text-center font-bold">Motor</th>
								<th class="px-6 py-4 text-center font-bold">Topsnelheid</th>
								<th class="px-6 py-4 text-center font-bold">Stijl Factor</th>
								<th class="px-6 py-4 text-center font-bold">Community</th>
							</tr>
						</thead>
						<tbody>
							<tr class="border-t bg-orange-50">
								<td class="px-6 py-4 font-bold text-orange-600">Super73 S2</td>
								<td class="px-6 py-4 text-center">€2.199</td>
								<td class="px-6 py-4 text-center font-bold text-green-600">750W Mid-Drive</td>
								<td class="px-6 py-4 text-center font-bold text-green-600">32 km/h</td>
								<td class="px-6 py-4 text-center font-bold text-green-600">⭐⭐⭐⭐⭐</td>
								<td class="px-6 py-4 text-center font-bold text-green-600">Wereldwijd</td>
							</tr>
							<tr class="border-t">
								<td class="px-6 py-4 font-semibold">RadRunner Plus</td>
								<td class="px-6 py-4 text-center text-green-600">€1.699</td>
								<td class="px-6 py-4 text-center">750W Hub</td>
								<td class="px-6 py-4 text-center">25 km/h</td>
								<td class="px-6 py-4 text-center">⭐⭐⭐</td>
								<td class="px-6 py-4 text-center">Beperkt</td>
							</tr>
							<tr class="border-t bg-gray-50">
								<td class="px-6 py-4 font-semibold">Cowboy 4</td>
								<td class="px-6 py-4 text-center">€2.490</td>
								<td class="px-6 py-4 text-center">250W</td>
								<td class="px-6 py-4 text-center">25 km/h</td>
								<td class="px-6 py-4 text-center">⭐⭐⭐⭐</td>
								<td class="px-6 py-4 text-center">Europa</td>
							</tr>
							<tr class="border-t">
								<td class="px-6 py-4 font-semibold">VanMoof S3</td>
								<td class="px-6 py-4 text-center">€1.998</td>
								<td class="px-6 py-4 text-center">250W</td>
								<td class="px-6 py-4 text-center">25 km/h</td>
								<td class="px-6 py-4 text-center">⭐⭐⭐⭐</td>
								<td class="px-6 py-4 text-center">Nederland</td>
							</tr>
						</tbody>
					</table>
				</div>

				<div class="mt-8 bg-orange-50 p-6 rounded-lg">
					<h3 class="font-bold text-orange-800 mb-3">💡 Waarom Super73 S2 kiezen:</h3>
					<ul class="space-y-2 text-orange-700">
						<li>• <strong>Krachtigste motor</strong> - 750W mid-drive vs 250W bij meeste concurrenten</li>
						<li>• <strong>Unieke lifestyle appeal</strong> - Geen andere fiets ziet er zo uit</li>
						<li>• <strong>Hogere topsnelheid</strong> - 32 km/h vs 25 km/h (onbegrensd gebruik)</li>
						<li>• <strong>Sterke community</strong> - Wereldwijde fanbase en events</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- Dutch Legal Status Section -->
		<section id="wetgeving" class="py-16">
			<div class="container mx-auto px-4">
				<h2 class="text-4xl font-bold text-center mb-12">Nederlandse Wetgeving & Kenteken</h2>

				<div class="grid lg:grid-cols-2 gap-12">
					<!-- Speed Limiter Required -->
					<div class="bg-red-50 p-8 rounded-lg">
						<h3 class="text-2xl font-bold mb-6 flex items-center">
							⚠️ Begrenzer Verplicht
						</h3>
						<div class="space-y-4">
							<div class="bg-red-100 p-4 rounded-lg">
								<p class="font-semibold text-red-800 mb-2">Super73 S2 rijdt 32 km/h standaard:</p>
								<ul class="text-sm space-y-1 text-red-700">
									<li>• Voor openbare weg: 25km/h begrenzer vereist</li>
									<li>• Zonder begrenzer alleen privéterrein</li>
									<li>• Begrenzer omkeerbaar voor off-road</li>
								</ul>
							</div>

							<div class="space-y-3">
								<div>
									<strong>Officiële Installateurs:</strong>
									<p class="text-gray-600">Super73 Nederland (Amsterdam), E-Motion Store (Rotterdam), Bike Totaal dealers</p>
								</div>
								<div>
									<strong>Kosten Begrenzer:</strong>
									<p class="text-gray-600">€199-349 installatie + certificaat</p>
								</div>
								<div class="bg-yellow-100 p-3 rounded border-l-4 border-yellow-500">
									<p class="text-yellow-800 text-sm">
										💡 <strong>Tip:</strong> Veel dealers bieden begrenzer-pakket aan bij aankoop.
									</p>
								</div>
							</div>
						</div>
					</div>

					<!-- Legal Requirements -->
					<div class="bg-blue-50 p-8 rounded-lg">
						<h3 class="text-2xl font-bold mb-6 flex items-center">
							⚖️ Snorfiets Vereisten
						</h3>
						<div class="space-y-4">
							<div class="flex items-start gap-4">
								<span class="bg-blue-100 p-2 rounded">🎂</span>
								<div>
									<strong>Minimumleeftijd 16 jaar</strong>
									<p class="text-gray-600">Geen rijbewijs nodig, wel geldig identiteitsbewijs meevoeren.</p>
								</div>
							</div>
							<div class="flex items-start gap-4">
								<span class="bg-blue-100 p-2 rounded">🛡️</span>
								<div>
									<strong>WA Verzekering Verplicht</strong>
									<p class="text-gray-600">€95-180/jaar. ANWB, Allianz en FBTO hebben goede tarieven.</p>
								</div>
							</div>
							<div class="flex items-start gap-4">
								<span class="bg-blue-100 p-2 rounded">🏷️</span>
								<div>
									<strong>RDW Kenteken</strong>
									<p class="text-gray-600">€67,20 eerste keer + €8,60/maand. COC-papieren bij Super73 dealers.</p>
								</div>
							</div>
							<div class="flex items-start gap-4">
								<span class="bg-blue-100 p-2 rounded">⛑️</span>
								<div>
									<strong>ECE-22.05 Helm</strong>
									<p class="text-gray-600">Bromfietshelm verplicht. Super73 verkoopt matching helmen.</p>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Total Cost Calculator -->
				<div class="mt-12 bg-gray-100 p-8 rounded-lg">
					<h3 class="text-2xl font-bold mb-6 text-center">🧮 Totale Kosten Overzicht</h3>
					<div class="grid md:grid-cols-2 gap-8">
						<div>
							<h4 class="font-bold mb-4">Eenmalige Kosten:</h4>
							<div class="space-y-2 text-sm">
								<div class="flex justify-between">
									<span>Super73 S2</span>
									<span class="font-semibold">€2.199</span>
								</div>
								<div class="flex justify-between">
									<span>25km/h Begrenzer + Certificaat</span>
									<span class="font-semibold">€274</span>
								</div>
								<div class="flex justify-between">
									<span>RDW Kenteken (eerste keer)</span>
									<span class="font-semibold">€67</span>
								</div>
								<div class="flex justify-between">
									<span>Super73 Helm + Accessoires</span>
									<span class="font-semibold">€149</span>
								</div>
								<div class="border-t pt-2 flex justify-between font-bold text-lg">
									<span>Totaal Starterskosten:</span>
									<span class="text-orange-600">€2.689</span>
								</div>
							</div>
						</div>
						<div>
							<h4 class="font-bold mb-4">Jaarlijkse Kosten:</h4>
							<div class="space-y-2 text-sm">
								<div class="flex justify-between">
									<span>WA Verzekering (ANWB basis)</span>
									<span class="font-semibold">€147/jaar</span>
								</div>
								<div class="flex justify-between">
									<span>RDW Kenteken (maandelijks)</span>
									<span class="font-semibold">€103/jaar</span>
								</div>
								<div class="flex justify-between">
									<span>Elektriciteitskosten (2500km/jaar)</span>
									<span class="font-semibold">€31/jaar</span>
								</div>
								<div class="flex justify-between">
									<span>Onderhoud (ketting, banden, service)</span>
									<span class="font-semibold">€190/jaar</span>
								</div>
								<div class="border-t pt-2 flex justify-between font-bold text-lg">
									<span>Totaal Per Jaar:</span>
									<span class="text-orange-600">€471</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Where to Buy Section -->
		<section id="kopen" class="py-16 bg-gray-50">
			<div class="container mx-auto px-4">
				<h2 class="text-4xl font-bold text-center mb-12">🛒 Waar te Kopen in Nederland</h2>

				<!-- Official Dealer Network -->
				<div class="grid lg:grid-cols-3 gap-8 mb-12">
					<div class="bg-white p-6 rounded-lg shadow-md">
						<div class="flex items-center mb-4">
							<span class="font-bold text-gray-700 mr-4">[Super73]</span>
							<div>
								<h3 class="font-bold">Super73 Europe</h3>
								<span class="text-sm text-orange-600">Officiële Website</span>
							</div>
						</div>
						<p class="text-gray-600 mb-4">Direct van de fabrikant. Nederlandse klantenservice en full warranty.</p>
						<div class="space-y-2 text-sm mb-4">
							<div>✅ 2 jaar internationale garantie</div>
							<div>✅ Gratis levering in Nederland</div>
							<div>✅ Officiële accessoires</div>
						</div>
						<a href={affiliateLinks.super73Official}
						   class="block bg-orange-600 hover:bg-orange-700 text-white text-center py-3 rounded-lg font-semibold transition-colors"
						   target="_blank" rel="noopener">
							Bestellen bij Super73
						</a>
					</div>

					<div class="bg-white p-6 rounded-lg shadow-md">
