---
import Layout from '../layouts/Layout.astro';

const title = "Talaria Sting MX5 Pro Kopen Nederland 2026 - Specs, Dealers & Wetgeving";
const description = "Talaria Sting MX5 Pro in Nederland: L1e-B bromfiets, 5.4kW motor, 60V 28.8Ah Samsung-cellen. AM rijbewijs en geel kenteken vereist. Officiële Benelux dealers.";
---

<Layout title={title} description={description}>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Talaria Sting MX5 Pro",
    "brand": {"@type": "Brand", "name": "Talaria"},
    "description": "Elektrische crosser L1e-B, 5.4kW, 60V 28.8Ah Samsung-cellen, 44 kg.",
    "category": "Elektrische bromfiets / crosser",
    "offers": {
      "@type": "Offer",
      "priceCurrency": "EUR",
      "price": "4599",
      "availability": "https://schema.org/InStock"
    },
    "author": {"@type": "Organization", "name": "CrosserGids"}
  }
  </script>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:underline">Home</a> &rsaquo;
      <a href="/vergelijk" class="hover:underline">Vergelijk</a> &rsaquo;
      Talaria Sting Nederland
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-2">Talaria Sting MX5 Pro in Nederland</h1>
    <p class="text-gray-500 text-sm mb-8">Bijgewerkt april 2026. Bron: <a href="https://bikecentreholland.nl/product/talaria-sting-mx5-pro/" class="text-blue-600 hover:underline" rel="noopener">Bike Centre Holland</a></p>

      <button onclick="document.getElementById('img-lightbox').showModal()" class="cursor-zoom-in group relative block w-full">
        <img
          src="https://bikecentreholland.nl/wp-content/uploads/2025/11/Talaria-Sting-MX5-PRO-1.png"
          alt="Talaria Sting MX5 Pro elektrische crosser"
          class="w-full max-h-80 object-contain rounded-lg bg-gray-50 mb-0 group-hover:opacity-90 transition-opacity"
          loading="eager"
        />
        <span class="absolute bottom-3 right-3 bg-black/50 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity">&#x26F6; Vergroten</span>
      </button>
      <div class="mb-8"></div>

      <!-- Lightbox -->
      <dialog id="img-lightbox" class="p-2 max-w-4xl w-full bg-gray-900 rounded-xl shadow-2xl backdrop:bg-black/80" onclick="this.close()">
        <img
          src="https://bikecentreholland.nl/wp-content/uploads/2025/11/Talaria-Sting-MX5-PRO-1.png"
          alt="Talaria Sting MX5 Pro elektrische crosser"
          class="w-full h-auto max-h-[85vh] object-contain"
        />
        <p class="text-center text-gray-400 text-xs mt-2">Klik ergens om te sluiten</p>
      </dialog>

    <!-- Legal category banner -->
    <div class="bg-orange-50 border border-orange-200 rounded p-4 mb-8">
      <p class="text-sm text-orange-800"><strong>Wettelijke categorie: L1e-B bromfiets.</strong> AM rijbewijs verplicht (vanaf 16 jaar). Geel kenteken en WA-verzekering verplicht. Helm verplicht. Niet op het fietspad.</p>
    </div>

    <!-- Specs -->
    <h2 class="text-xl font-bold text-gray-900 mb-4">Technische specificaties</h2>
    <div class="overflow-x-auto mb-8">
      <table class="w-full text-sm border-collapse">
        <tbody>
          <tr class="border-b border-gray-100 hover:bg-gray-50">
            <td class="py-2 pr-4 text-gray-500 w-40">Motor</td>
            <td class="py-2 font-medium">5.400W (5,4 kW) mid-drive borstelloze motor</td>
          </tr>
          <tr class="border-b border-gray-100 hover:bg-gray-50">
            <td class="py-2 pr-4 text-gray-500">Batterij</td>
            <td class="py-2 font-medium">60V 28.8Ah (1.728Wh) met Samsung 21700-cellen</td>
          </tr>
          <tr class="border-b border-gray-100 hover:bg-gray-50">
            <td class="py-2 pr-4 text-gray-500">Bereik</td>
            <td class="py-2 font-medium">60&ndash;90 km (gemengd gebruik)</td>
          </tr>
          <tr class="border-b border-gray-100 hover:bg-gray-50">
            <td class="py-2 pr-4 text-gray-500">Topsnelheid</td>
            <td class="py-2 font-medium">45 km/h (EU-begrensd als bromfiets)</td>
          </tr>
          <tr class="border-b border-gray-100 hover:bg-gray-50">
            <td class="py-2 pr-4 text-gray-500">Gewicht</td>
            <td class="py-2 font-medium">44 kg</td>
          </tr>
          <tr class="border-b border-gray-100 hover:bg-gray-50">
            <td class="py-2 pr-4 text-gray-500">Frame</td>
            <td class="py-2 font-medium">Aluminiumlegering, motocross-geometrie</td>
          </tr>
          <tr class="border-b border-gray-100 hover:bg-gray-50">
            <td class="py-2 pr-4 text-gray-500">Vering voor</td>
            <td class="py-2 font-medium">USD-vork 38mm, 180 mm veerweg</td>
          </tr>
          <tr class="border-b border-gray-100 hover:bg-gray-50">
            <td class="py-2 pr-4 text-gray-500">Vering achter</td>
            <td class="py-2 font-medium">DNM mono-demper, volledig instelbaar</td>
          </tr>
          <tr class="border-b border-gray-100 hover:bg-gray-50">
            <td class="py-2 pr-4 text-gray-500">Remmen</td>
            <td class="py-2 font-medium">Hydraulisch schijf voor &amp; achter (203mm)</td>
          </tr>
          <tr class="border-b border-gray-100 hover:bg-gray-50">
            <td class="py-2 pr-4 text-gray-500">Laadtijd</td>
            <td class="py-2 font-medium">ca. 3,5 uur (met snellader)</td>
          </tr>
          <tr class="border-b border-gray-100 hover:bg-gray-50">
            <td class="py-2 pr-4 text-gray-500">Homologatie</td>
            <td class="py-2 font-medium">L1e-B (bromfiets, AM rijbewijs)</td>
          </tr>
          <tr class="border-b border-gray-100 hover:bg-gray-50">
            <td class="py-2 pr-4 text-gray-500">Prijs (2026)</td>
            <td class="py-2 font-medium">&euro;4.599 (Talaria Benelux adviesprijs)</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- What you need -->
    <h2 class="text-xl font-bold text-gray-900 mb-4">Wat heb je nodig in Nederland?</h2>
    <ul class="text-sm text-gray-700 space-y-2 mb-8">
      <li><strong>Rijbewijs:</strong> AM rijbewijs (bromfietsrijbewijs). Minimale leeftijd 16 jaar.</li>
      <li><strong>Kenteken:</strong> Geel RDW-kenteken. Talaria Benelux levert de CoC mee bij aankoop. Kosten RDW: &euro;21,50.</li>
      <li><strong>Verzekering:</strong> WA-verzekering verplicht. Reken op ca. &euro;80&ndash;150/jaar voor een bromfietsverzekering.</li>
      <li><strong>Helm:</strong> Goedgekeurde bromfietshelm verplicht.</li>
    </ul>

    <!-- Talaria vs Sur-Ron -->
    <h2 class="text-xl font-bold text-gray-900 mb-3">Talaria Sting MX5 Pro vs Sur-Ron Light Bee X</h2>
    <p class="text-sm text-gray-600 mb-4">Beide zijn L1e-B bromfietsen in het &euro;4.500&ndash;5.200 segment. Gedetailleerde vergelijking: <a href="/sur-ron-vs-talaria" class="text-blue-600 hover:underline">Sur-Ron vs Talaria &rarr;</a></p>
    <div class="overflow-x-auto mb-8">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="bg-gray-100">
            <th class="text-left p-3 border border-gray-200"></th>
            <th class="text-left p-3 border border-gray-200">Talaria Sting MX5 Pro</th>
            <th class="text-left p-3 border border-gray-200">Sur-Ron Light Bee X</th>
          </tr>
        </thead>
        <tbody>
          <tr class="hover:bg-gray-50">
            <td class="p-3 border border-gray-200 text-gray-500">Prijs</td>
            <td class="p-3 border border-gray-200 font-medium">&euro;4.599</td>
            <td class="p-3 border border-gray-200">&euro;5.199</td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="p-3 border border-gray-200 text-gray-500">Motor</td>
            <td class="p-3 border border-gray-200">5,4 kW</td>
            <td class="p-3 border border-gray-200">6 kW</td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="p-3 border border-gray-200 text-gray-500">Batterij</td>
            <td class="p-3 border border-gray-200 font-medium">60V 28.8Ah Samsung</td>
            <td class="p-3 border border-gray-200">60V 32Ah</td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="p-3 border border-gray-200 text-gray-500">Gewicht</td>
            <td class="p-3 border border-gray-200 font-medium">44 kg</td>
            <td class="p-3 border border-gray-200">47 kg</td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="p-3 border border-gray-200 text-gray-500">Dealers NL</td>
            <td class="p-3 border border-gray-200">15 (Talaria Benelux)</td>
            <td class="p-3 border border-gray-200">4</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Where to buy -->
    <h2 class="text-xl font-bold text-gray-900 mb-4">Kopen &amp; dealers</h2>
    <p class="text-sm text-gray-700 mb-4">
      Talaria wordt in de Benelux gedistribueerd door Talaria Benelux. Ze hebben 15 erkende dealers in Nederland verspreid over het land. Officieel: <a href="https://talaria-benelux.com/dealers/" class="text-blue-600 hover:underline" rel="noopener">talaria-benelux.com/dealers &rarr;</a>
    </p>
    <p class="text-sm text-gray-700 mb-8">
      Overzicht met adressen en contact: <a href="/dealers#talaria" class="text-blue-600 hover:underline">Talaria dealers Nederland &rarr;</a>
    </p>

    <!-- FAQ -->
    <h2 class="text-xl font-bold text-gray-900 mb-4">Veelgestelde vragen</h2>

    <details class="border border-gray-200 rounded mb-3">
      <summary class="p-4 font-medium cursor-pointer select-none hover:bg-gray-50">Wat maakt de Samsung-cellen in de Talaria beter?</summary>
      <div class="p-4 pt-0 text-gray-700 text-sm">
        Samsung 21700-cellen (ook gebruikt in Tesla Model 3) hebben een hogere energiedichtheid en betere thermische stabiliteit dan goedkopere Chinese no-name cellen. In de praktijk betekent dit: betere prestaties bij koude, langer leven bij snelladen, en consistenter bereik over meerdere jaren.
      </div>
    </details>

    <details class="border border-gray-200 rounded mb-3">
      <summary class="p-4 font-medium cursor-pointer select-none hover:bg-gray-50">Is de Talaria Sting geschikt voor dagelijks woon-werkverkeer?</summary>
      <div class="p-4 pt-0 text-gray-700 text-sm">
        De Talaria is primair een off-road crosser, maar met L1e-B typegoedkeuring mag hij op de weg. Met 45 km/h topsnelheid en 60&ndash;90 km bereik is hij bruikbaar voor kortere pendeldistances. Let op: geen fietspad, wel rijbaan. En qua zitpositie en ergonomie is het een crosser, geen comfortabel stadsvoertuig.
      </div>
    </details>

    <details class="border border-gray-200 rounded mb-3">
      <summary class="p-4 font-medium cursor-pointer select-none hover:bg-gray-50">Wat is het verschil tussen de Talaria Sting R en MX5 Pro?</summary>
      <div class="p-4 pt-0 text-gray-700 text-sm">
        De MX5 Pro is de gefacelifte versie met Samsung 21700-cellen, verbeterde USD-vork en bijgewerkte motor. De Sting R is een oudere generatie met vergelijkbare geometrie maar minder geavanceerde batterijcellen. In Nederland verkoopt Talaria Benelux voornamelijk de MX5 Pro.
      </div>
    </details>

    <div class="mt-8 pt-6 border-t border-gray-200">
      <h3 class="font-semibold text-gray-800 mb-3">Gerelateerd</h3>
      <ul class="space-y-2 text-sm text-blue-600">
        <li><a href="/sur-ron-vs-talaria" class="hover:underline">Sur-Ron Light Bee X vs Talaria Sting, uitgebreide vergelijking</a></li>
        <li><a href="/elektrische-crosser-rijbewijs" class="hover:underline">Welk rijbewijs heb je nodig?</a></li>
        <li><a href="/vergelijk" class="hover:underline">Alle modellen vergelijken</a></li>
      </ul>
    </div>

  </div>
</Layout>
